# =============================================================================
# AdInsight Agent — Environment Variables
# 사용 방법: cp .env.example .env  →  값 채우기  →  절대 커밋 금지
# =============================================================================

# ----- Airflow -----
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=./
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__SECRET_KEY=change-me-airflow-secret
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin

# ----- Postgres (Warehouse + Airflow metadata + Superset metadata) -----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=adinsight
# 웨어하우스 외에 별도 DB로 분리 운영
AIRFLOW_DB=airflow_meta
SUPERSET_DB=superset_meta

# ----- Superset -----
SUPERSET_SECRET_KEY=change-me-superset-secret
SUPERSET_LOAD_EXAMPLES=false

# ----- Redis (Celery broker) -----
REDIS_HOST=redis
REDIS_PORT=6379

# ----- LLM Provider 선택 ('gemini' | 'claude' | 'openai') -----
LLM_PROVIDER=gemini
LLM_MODEL_PRIMARY=gemini-2.5-flash
LLM_MODEL_FALLBACK=claude-haiku-4-5-20251001

# ----- API Keys (필요한 것만 채우기) -----
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
HUGGINGFACE_TOKEN=

# ----- Data Generation -----
SEED=42

# ----- dbt -----
DBT_PROFILES_DIR=./dbt
DBT_TARGET=dev

# ----- Agent (Text2SQL) -----
AGENT_DB_USER=agent_readonly
AGENT_DB_PASSWORD=change-me-readonly
AGENT_QUERY_TIMEOUT_S=30
AGENT_MAX_ROWS=1000
AGENT_TOP_K_SCHEMA=8

# ----- Text2SQL v2 Provider/Gateway -----
# Serving API -> gateway adapter
TEXT2SQL_PROVIDER=mock
TEXT2SQL_PROVIDER_URL=http://127.0.0.1:8010/text2sql/generate
TEXT2SQL_PROVIDER_API_KEY=
TEXT2SQL_PROVIDER_TIMEOUT_SECONDS=20
TEXT2SQL_V2_REGISTRY_FALLBACK_ENABLED=true
TEXT2SQL_EVAL_MODEL_LABEL=

# Gateway backend: mock | ollama | openai | gemini
TEXT2SQL_GATEWAY_BACKEND=mock
TEXT2SQL_GATEWAY_API_KEY=

# Ollama backend
TEXT2SQL_OLLAMA_URL=http://127.0.0.1:11434/api/generate
TEXT2SQL_OLLAMA_MODEL=qwen2.5-coder:7b
TEXT2SQL_OLLAMA_TIMEOUT_SECONDS=60
TEXT2SQL_OLLAMA_TEMPERATURE=0
TEXT2SQL_OLLAMA_SEED=7

# OpenAI backend
TEXT2SQL_OPENAI_API_KEY=
TEXT2SQL_OPENAI_MODEL=gpt-5.4-mini-2026-03-17
TEXT2SQL_OPENAI_TIMEOUT_SECONDS=60
TEXT2SQL_OPENAI_TEMPERATURE=

# Gemini backend
TEXT2SQL_GEMINI_API_KEY=
TEXT2SQL_GEMINI_MODEL=gemini-3.1-flash-lite
TEXT2SQL_GEMINI_TIMEOUT_SECONDS=60

# ----- Notifications (옵션) -----
SLACK_WEBHOOK_URL=
